VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: fallback if you don't want to store per-company in Supabase
VITE_META_AD_ACCOUNT_ID=act_1234567890

# Optional: Meta Graph API version (default: v19.0)
VITE_META_GRAPH_VERSION=v19.0

# Optional: Facebook OAuth scopes (space-separated)
# If you see "Invalid Scopes: email", try: public_profile ads_read
VITE_FACEBOOK_SCOPES=public_profile email ads_read
