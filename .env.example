VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: fallback if you don't want to store per-company in Supabase
VITE_META_AD_ACCOUNT_ID=act_1234567890

# Optional: Meta Graph API version (default: v19.0)
VITE_META_GRAPH_VERSION=v19.0

# Optional: Facebook OAuth scopes (space- or comma-separated)
# If you see "Invalid Scopes: email", keep it without `email`.
#
# To enable the Instagram module (organic metrics), add the scopes below.
# The user will need to log out and sign in again with Facebook so the new
# scopes are requested. The Meta app must have instagram_manage_insights approved.
#
# Minimum scopes (paid traffic only):
# VITE_FACEBOOK_SCOPES=public_profile ads_read
#
# Full scopes (paid traffic + organic Instagram):
VITE_FACEBOOK_SCOPES=public_profile ads_read instagram_basic instagram_manage_insights pages_show_list pages_read_engagement

# -----------------------------------------------------------------------------
# Instagram - Edge Function instagram-token-exchange (server-side, Supabase secrets)
# Converts the short-lived token (~1h) into a long-lived token (~60 days).
# Configure in: Supabase Dashboard -> Edge Functions -> Secrets
#   META_APP_ID=<your Meta App ID>
#   META_APP_SECRET=<your Meta App Secret>
#   META_GRAPH_VERSION=v19.0   (optional, default is already v19.0)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Meta Ads - Edge Function meta-token-exchange
# Uses the same secrets above to exchange the short-lived Facebook token for a
# long-lived token (~60 days), reducing how often users need to reconnect.
# Deploy:
#   supabase functions deploy meta-token-exchange
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Phase 4 (AI)
# The LLM key is configured per user in the UI and stays only in the browser.
# -----------------------------------------------------------------------------
