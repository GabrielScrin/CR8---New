VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: fallback if you don't want to store per-company in Supabase
VITE_META_AD_ACCOUNT_ID=act_1234567890

# Optional: Meta Graph API version (default: v19.0)
VITE_META_GRAPH_VERSION=v19.0

# Optional: Facebook OAuth scopes (space- or comma-separated)
# If you see "Invalid Scopes: email", keep it without `email`.
#
# Para habilitar o módulo Instagram (métricas orgânicas), adicione os escopos abaixo.
# O usuário precisará fazer logout e entrar novamente com Facebook para que os novos
# escopos sejam solicitados. O app Meta precisa ter permissão instagram_manage_insights aprovada.
#
# Scopes mínimos (só tráfego pago):
# VITE_FACEBOOK_SCOPES=public_profile ads_read
#
# Scopes completos (tráfego pago + Instagram orgânico):
VITE_FACEBOOK_SCOPES=public_profile ads_read instagram_basic instagram_manage_insights pages_show_list pages_read_engagement

# -----------------------------------------------------------------------------
# Instagram — Edge Function instagram-token-exchange (server-side, Supabase secrets)
# Necessário para converter o token curto (~1h) em token de longa duração (~60 dias).
# Configure em: Supabase Dashboard → Edge Functions → Secrets
#   META_APP_ID=<seu App ID do Meta for Developers>
#   META_APP_SECRET=<seu App Secret do Meta for Developers>
#   META_GRAPH_VERSION=v19.0   (opcional, default já é v19.0)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Phase 4 (AI)
# A chave de LLM é configurada por usuário (UI Agente IA) e fica apenas no navegador.
# -----------------------------------------------------------------------------
